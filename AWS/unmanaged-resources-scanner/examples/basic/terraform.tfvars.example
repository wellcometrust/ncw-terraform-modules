# =============================================================================
# terraform.tfvars.example
#
# Copy this to terraform.tfvars and edit the values, then:
#
#   terraform init -upgrade
#   terraform apply
#   $(terraform output -raw scan_command)   # ← run the scan
# =============================================================================

profile          = "wellcomedevelopers_AdministratorAccess"
aws_account_id   = "123456789012"
aws_account_name = "wellcomedevelopers-prod"
repo_name        = "wellcomedevelopers-repo"
regions          = ["eu-west-1", "eu-west-2"]

# Optional
terraform_dir = "./aws"    # defaults to the root module dir if omitted
json_output   = false
